# Database
DATABASE_URL=postgresql://mail:mailpassword@localhost:5432/mailplatform

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Amazon SES SMTP (outbound)
SES_REGION=eu-central-1
SES_SMTP_USER=your-ses-smtp-username
SES_SMTP_PASS=your-ses-smtp-password

# Amazon SES Inbound (S3 + SNS)
SES_INBOUND_S3_BUCKET=your-inbound-email-bucket
SES_INBOUND_SNS_TOPIC_ARN=arn:aws:sns:eu-central-1:123456789:inbound-email

# AWS Credentials (S3 fetch for inbound emails)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Application URLs
WEB_URL=https://mail.yourdomain.com
NEXT_PUBLIC_API_URL=https://mail.yourdomain.com/api/v1
API_PORT=3001
WEB_PORT=3000

# Rate Limiting
MAILBOX_SEND_RATE_LIMIT=30

# Worker
WORKER_CONCURRENCY=5

# Seed (development only)
SEED_ORG_NAME=Demo Organization
SEED_ORG_SLUG=demo-org
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123
