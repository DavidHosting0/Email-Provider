{
  "name": "email-provider",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm db:generate && pnpm -r build",
    "postinstall": "pnpm db:generate",
    "dev": "pnpm -r --parallel dev",
    "db:generate": "pnpm --filter @email-provider/database generate",
    "db:migrate": "pnpm --filter @email-provider/database migrate",
    "db:seed": "pnpm --filter @email-provider/database seed",
    "db:push": "pnpm --filter @email-provider/database push",
    "db:reparse": "pnpm --filter @email-provider/worker reparse",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.1"
    }
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "dotenv": "^16.4.7"
  }
}
